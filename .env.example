# =============================================
# LOCAL DEVELOPMENT (docker-compose)
# =============================================
# Copy this to .env and fill values before running docker-compose
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=zalo_db
MYSQL_USER=zalo
MYSQL_PASSWORD=zalopass

# =============================================
# BACKEND ENV (dùng cho cả local và production)
# =============================================

# --- Local Docker Compose ---
# DATABASE_URL=mysql+pymysql://zalo:zalopass@db:3306/zalo_db
# USE_LOCAL_DB=True

# --- Production (Render / VPS) ---
# Thay bằng connection string MySQL thật của bạn
# Ví dụ PlanetScale:   mysql+pymysql://user:pass@host.us-east-1.psdb.cloud/dbname?ssl_ca=/etc/ssl/certs/ca-certificates.crt
# Ví dụ Aiven:         mysql+pymysql://user:pass@host.aivencloud.com:PORT/dbname
# Ví dụ VPS MySQL:     mysql+pymysql://root:yourpass@157.10.199.166:3306/bookingservicesiovn_zalominidb
DATABASE_URL=mysql+pymysql://zalo:zalopass@db:3306/zalo_db
USE_LOCAL_DB=False

# Đổi thành chuỗi ngẫu nhiên dài cho production
SECRET_KEY=change-me
